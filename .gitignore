# =====================================================
# FIFA 2026 Tickets - .gitignore
# =====================================================

# ----- Secrets & env -----
.env
.env.local
.env.*.local
*.dev-backup
**/.env
**/.env.local
*.key
*.pem
*.pfx
.aiox/secrets-*.txt

# ----- Dependencies -----
node_modules/
**/node_modules/

# ----- Build outputs -----
dist/
build/
**/dist/
**/build/

# ----- .NET build artifacts -----
[Bb]in/
[Oo]bj/
**/[Bb]in/
**/[Oo]bj/
*.user

# Vite cache
.vite/
**/.vite/

# ----- Logs -----
*.log
logs/
**/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----- Temp / artefatos -----
api.zip
web.zip
# Bacpac: distribuído pelo Blob Storage (container copa2026), não versionado no repo
*.bacpac
*.bacpac-extract/
**/.bacpac-extract/

# ----- Pacote dos alunos (gerado localmente; publicado no Blob Storage) -----
_pacote-alunos/

# ----- Editores / OS -----
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
*.swp
*.swo

# ----- Lock files duplicados -----
bun.lockb
yarn.lock
pnpm-lock.yaml

# ----- Bicep build artifacts -----
*.bicep.json

# ----- Azure local credentials -----
.azure/

# ----- Coverage -----
coverage/
*.lcov

# Dependencies (AIOX)
node_modules

# AIOX Local (AIOX)
.aiox-core/local/
.claude/settings.local.json
.aiox/install-log.txt

# ----- Tooling de IA / assistentes (não versionar no repo do app) -----
.aiox-core/
.aiox/
.antigravity/
.claude/
.codex/
.cursor/
.gemini/
.kimi/
.github/agents/
infra/.claude/
