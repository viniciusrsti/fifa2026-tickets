            <Array as="points"><mxPoint x="115" y="700" /><mxPoint x="1373" y="700" /></Array>
          </mxGeometry>
        </mxCell>

        <!-- ============ LEGENDA / NOTAS ============ -->
        <mxCell id="noteMuda" value="O que MUDA vs 2.3:  ① authority → CIAM (ciamlogin.com no authV2.ts e no AddJwtBearer)  ·  ② 2º esquema admin (AddJwtBearer &#39;Admin&#39; workforce) + PolicyScheme &#39;Selector&#39;  ·  ③ migration aditiva users.entra_oid (phase-04-ciam-link.sql)" style="rounded=1;arcSize=6;html=1;fillColor=#F3EEFB;strokeColor=#8661C5;fontColor=#5C2E91;fontSize=11;align=left;verticalAlign=middle;spacingLeft=12;spacingRight=12;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="48" y="720" width="830" height="56" as="geometry" />
        </mxCell>
        <mxCell id="noteNaoMuda" value="O que NÃO muda (issuer-agnóstico):  o pipeline oid → X-Entra-OID → entra_oid é idêntico a F1/F3.  PurchaseEntryFunction, Service Bus, Consumer e purchases.entra_oid (zero-DDL) intactos.  O gateway valida QUALQUER issuer por discovery (ADE-004 Inv 4) — adicionar o CIAM é configuração, não reescrita." style="rounded=1;arcSize=6;html=1;fillColor=#FFF7E6;strokeColor=#B58A00;fontColor=#8A6D00;fontSize=11;align=left;verticalAlign=middle;spacingLeft=12;spacingRight=12;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="890" y="720" width="830" height="56" as="geometry" />
        </mxCell>

        <mxCell id="legendFlow" value="Fluxo (animado):  login CIAM / admin → ① POST /purchase (Bearer) → Gateway YARP (CORS · rate-limit 429 · cache HIT · dual-issuer JWT · Selector · X-Entra-OID) → ② proxy → ③ INSERT purchases.entra_oid → ④ fan-out F1 (Service Bus → Consumer → SQL)  ·  ⑤ migração de cadastro users.entra_oid (hands-on)" style="text;html=1;fontSize=10;align=left;verticalAlign=middle;fontColor=#605E5C;" vertex="1" parent="1">
          <mxGeometry x="48" y="788" width="1680" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legendStencil" value="Nota de stencils: Azure2 não possui ícone dedicado de &#39;Entra External ID&#39; nem de &#39;Container Apps&#39;. Fallbacks: Azure_AD_B2C.svg p/ CIAM (B2C é o ancestral do External ID), Azure_Active_Directory.svg p/ workforce, App_Services.svg p/ o Container App do gateway. Rótulos textuais nomeiam o produto correto (Entra External ID / Container App)." style="text;html=1;fontSize=9;fontStyle=2;align=left;verticalAlign=middle;fontColor=#8A8886;" vertex="1" parent="1">
          <mxGeometry x="48" y="812" width="1680" height="30" as="geometry" />
        </mxCell>
        <mxCell id="foot" value="TFTEC Cloud · Copa do Mundo Azure 2026 — Quartas de Final (F2/F3) · story 2.11 · fonte: Dev Notes &#39;Arquitetura técnica completa (estado pós-Quartas)&#39; + ADE-007 v1.1 Inv 1/2/3/5/7" style="text;html=1;fontSize=11;fontColor=#605E5C;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="48" y="848" width="1400" height="22" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
