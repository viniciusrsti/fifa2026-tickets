          <mxGeometry x="1345" y="560" width="56" height="56" as="geometry" />
        </mxCell>
        <mxCell id="sqlAxis1" value="EIXO COMPRA (transacional) — ZERO-DDL&#10;purchases.entra_oid (oid da compra v2)&#10;coexiste com purchases.user_id (v1) na mesma tabela" style="rounded=1;arcSize=8;html=1;fillColor=#E6F7F4;strokeColor=#0E8A7D;fontColor=#0E8A7D;fontSize=9;align=left;verticalAlign=middle;spacingLeft=8;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="1430" y="548" width="280" height="48" as="geometry" />
        </mxCell>
        <mxCell id="sqlAxis2" value="EIXO CADASTRO (durável) — 1 migration aditiva&#10;users.entra_oid (GUID CIAM) via phase-04-ciam-link.sql&#10;mesma linha de users: password (bcrypt v1) + entra_oid (CIAM v2) = COEXISTE" style="rounded=1;arcSize=8;html=1;fillColor=#FFF7E6;strokeColor=#B58A00;fontColor=#8A6D00;fontSize=9;align=left;verticalAlign=middle;spacingLeft=8;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="1430" y="602" width="280" height="56" as="geometry" />
        </mxCell>

        <!-- ============ EDGES — fluxo numerado ============ -->
        <!-- login CIAM -->
        <mxCell id="eCiamLogin" value="login CIAM (PKCE)" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=0;endArrow=block;flowAnimation=1;strokeColor=#0E8A7D;strokeWidth=2;fontColor=#0E8A7D;fontSize=10;labelBackgroundColor=#FFFFFF;dashed=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.2;entryDx=0;entryDy=0;" edge="1" parent="1" source="ciam" target="browser">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eAdminLogin" value="login admin" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=0;endArrow=block;flowAnimation=1;strokeColor=#0078D4;strokeWidth=2;fontColor=#0078D4;fontSize=10;labelBackgroundColor=#FFFFFF;dashed=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.8;entryDx=0;entryDy=0;" edge="1" parent="1" source="workforce" target="browser">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 1) POST /purchase -->
        <mxCell id="e1" value="① POST /purchase&#10;Authorization: Bearer &lt;token&gt;" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=0;endArrow=block;flowAnimation=1;strokeColor=#5C2E91;strokeWidth=3;fontColor=#5C2E91;fontSize=11;fontStyle=1;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.32;entryDx=0;entryDy=0;" edge="1" parent="1" source="browser" target="gwContainer">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 2) gateway → entry (X-Entra-OID) -->
        <mxCell id="e2" value="② proxy + X-Entra-OID" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=0;endArrow=block;flowAnimation=1;strokeColor=#B58A00;strokeWidth=2.5;fontColor=#8A6D00;fontSize=10;fontStyle=1;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.82;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="pProxy" target="entry">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 3) entry → SQL (grava purchases.entra_oid) -->
        <mxCell id="e3" value="③ INSERT purchases.entra_oid" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=0;endArrow=block;flowAnimation=1;strokeColor=#0E8A7D;strokeWidth=2;fontColor=#0E8A7D;fontSize=10;labelBackgroundColor=#FFFFFF;exitX=0.2;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="entry" target="sql">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="1310" y="540" /></Array>
          </mxGeometry>
        </mxCell>

        <!-- 4) fan-out F1: entry → sbus → consumer → sql -->
        <mxCell id="e4a" value="④ fan-out" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=0;endArrow=block;flowAnimation=1;strokeColor=#0E8A7D;strokeWidth=2;fontColor=#0E8A7D;fontSize=10;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="entry" target="sbus">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4b" value="entrega" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=0;endArrow=block;flowAnimation=1;strokeColor=#0E8A7D;strokeWidth=2;fontColor=#0E8A7D;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="sbus" target="consumer">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4c" value="INSERT" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=0;endArrow=block;flowAnimation=1;strokeColor=#0E8A7D;strokeWidth=2;fontColor=#0E8A7D;fontSize=10;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.9;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="consumer" target="sql">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- telemetria -->
        <mxCell id="eTel1" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=0;endArrow=open;dashed=1;strokeColor=#68217A;" edge="1" parent="1" source="entry" target="appi">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eTel2" value="telemetria" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=0;endArrow=open;dashed=1;strokeColor=#68217A;fontColor=#68217A;fontSize=9;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="consumer" target="appi">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- migração v1→CIAM (cadastro) -->
        <mxCell id="eMig" value="⑤ migração hands-on v1→CIAM&#10;UPDATE users SET entra_oid (idempotente)" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=0;endArrow=block;dashed=1;strokeColor=#B58A00;strokeWidth=2;fontColor=#8A6D00;fontSize=10;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="ciam" target="sql">
