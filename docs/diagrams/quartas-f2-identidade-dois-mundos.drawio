        <mxCell id="title" value="🏆 Quartas de Final (F2/F3) — Identidade em DOIS MUNDOS · Gateway YARP guardião issuer-agnóstico" style="text;html=1;fontSize=20;fontStyle=1;align=left;verticalAlign=middle;fontColor=#B58A00;" vertex="1" parent="1">
