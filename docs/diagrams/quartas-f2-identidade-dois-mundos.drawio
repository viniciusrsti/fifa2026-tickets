          <mxGeometry x="785" y="180" width="410" height="34" as="geometry" />
        </mxCell>
        <mxCell id="pRate" value="AddRateLimiter — fixed window 5/min → 6ª chamada = HTTP 429" style="rounded=1;arcSize=10;html=1;fillColor=#EFF6FC;strokeColor=#0078D4;fontColor=#0078D4;fontSize=10;align=left;verticalAlign=middle;spacingLeft=10;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="785" y="222" width="410" height="34" as="geometry" />
        </mxCell>
        <mxCell id="pCache" value="AddOutputCache — 30s no GET status · 2ª resposta X-Cache: HIT (&lt;50ms)" style="rounded=1;arcSize=10;html=1;fillColor=#EFF6FC;strokeColor=#0078D4;fontColor=#0078D4;fontSize=10;align=left;verticalAlign=middle;spacingLeft=10;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="785" y="264" width="410" height="34" as="geometry" />
