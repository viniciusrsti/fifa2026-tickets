          <mxGeometry x="795" y="316" width="390" height="18" as="geometry" />
        </mxCell>
        <mxCell id="pCiamJwt" value="AddJwtBearer &quot;Ciam&quot;  →  discovery &lt;tenant&gt;.ciamlogin.com/.../v2.0&#10;valida iss/aud/assinatura/exp do token CIAM" style="rounded=1;arcSize=10;html=1;fillColor=#E6F7F4;strokeColor=#0E8A7D;fontColor=#0E8A7D;fontSize=10;align=left;verticalAlign=middle;spacingLeft=10;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="795" y="338" width="390" height="42" as="geometry" />
        </mxCell>
        <mxCell id="pAdminJwt" value="AddJwtBearer &quot;Admin&quot;  →  discovery login.microsoftonline.com/&lt;tenant&gt;/v2.0&#10;valida token workforce · AdminOnly → 403 p/ cliente CIAM" style="rounded=1;arcSize=10;html=1;fillColor=#EFF6FC;strokeColor=#0078D4;fontColor=#0078D4;fontSize=10;align=left;verticalAlign=middle;spacingLeft=10;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="795" y="386" width="390" height="42" as="geometry" />
        </mxCell>
        <mxCell id="pSelector" value="★ PolicyScheme &quot;Selector&quot; — roteia pelo ISSUER do token (CIAM vs workforce)&#10;ponto novo das Quartas: um gateway, dois mundos, seleção de esquema (não troca de string)" style="rounded=1;arcSize=10;html=1;fillColor=#F3EEFB;strokeColor=#8661C5;fontColor=#5C2E91;fontSize=10;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=10;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="795" y="434" width="390" height="42" as="geometry" />
        </mxCell>
        <mxCell id="pOid" value="extrai claim oid → injeta header X-Entra-OID (anti-spoofing: strip do header de entrada) · ISSUER-AGNÓSTICO (herdado de 2.3)" style="rounded=1;arcSize=10;html=1;fillColor=#FFF7E6;strokeColor=#B58A00;fontColor=#8A6D00;fontSize=10;align=left;verticalAlign=middle;spacingLeft=10;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="785" y="486" width="410" height="44" as="geometry" />
        </mxCell>
